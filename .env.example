BUSINESS_COMMISSION=100
DRIVER_COMMISSION=100

# ============================================
# ORDER CONFIGURATION
# ============================================
REGRET_PERIOD_SECONDS=60
BUSINESS_CALL_DELAY_MINUTES=3
FUND_HOLD_HOURS=1

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
