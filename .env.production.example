# MOUZO - Configuración de Producción (Replit)
# Copia este archivo a .env.production y actualiza los valores

# URLs de Producción
EXPO_PUBLIC_API_URL=https://mouzo.replit.app
EXPO_PUBLIC_BACKEND_URL=https://mouzo.replit.app
EXPO_PUBLIC_FRONTEND_URL=https://mouzo.replit.app

# Entorno
EXPO_PUBLIC_NODE_ENV=production

# Información de la App
EXPO_PUBLIC_APP_NAME=MOUZO
EXPO_PUBLIC_APP_VERSION=1.0.1

# Nota: Las variables sensibles (API keys, passwords) deben configurarse
# en Replit Secrets, NO en este archivo
